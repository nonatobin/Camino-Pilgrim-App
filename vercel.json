{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/__/auth/:path*", "destination": "https://gen-lang-client-0715958804.firebaseapp.com/__/auth/:path*" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|__/).*)", "destination": "/index.html" }
  ]
}
