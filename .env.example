# ============================================================================
# Camino Pilgrim App â Environment Variables
# ============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production (Vercel), add these in the Vercel dashboard:
#   Settings â Environment Variables
#
# Variables prefixed with VITE_ are exposed to the browser (client-side).
# Variables WITHOUT the prefix are server-only (API routes).
# ============================================================================

# ---------------------------------------------------------------------------
# APP URL (auto-detected if not set, but explicit is safer for production)
# ---------------------------------------------------------------------------
# Local dev:  http://localhost:5173
# Production: https://project-ccff5.vercel.app  (or your custom domain)
APP_URL=http://localhost:5173

# Also expose to the client for frontend redirect logic
VITE_APP_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# GOOGLE MAPS + PLACES  (required for route map & nearby places)
# ---------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
# Enable:   Maps JavaScript API, Places API (New)
VITE_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# GEMINI AI  (required for voice assistant & voice parsing)
# ---------------------------------------------------------------------------
# Get from: https://aistudio.google.com/apikey
# Used by:  LiveAssistant (Gemini 3.1 Flash Live), voiceParser, Translate fallback
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# GOOGLE TRANSLATE  (optional â falls back to Gemini if not set)
# ---------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
# Enable:   Cloud Translation API
# Note:     If you skip this, the Translate tab will use Gemini for translations
VITE_GOOGLE_TRANSLATE_API_KEY=

# ---------------------------------------------------------------------------
# OPENWEATHERMAP  (optional â shows demo data if not set)
# ---------------------------------------------------------------------------
# Get from: https://openweathermap.org/api (free tier is fine)
VITE_OPENWEATHER_API_KEY=

# ---------------------------------------------------------------------------
# GOOGLE CALENDAR OAUTH  (required for calendar sync feature)
# ---------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
# Create:   OAuth 2.0 Client ID (Web application type)
# Add redirect URIs in Google Cloud Console:
#   - http://localhost:5173/api/auth/calendar/callback     (for local dev)
#   - https://project-ccff5.vercel.app/api/auth/calendar/callback  (for production)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# FEATURE FLAGS  (all default to true â set to false to disable)
# ---------------------------------------------------------------------------
# These let you turn features on/off without code changes.
# Useful for gradual rollouts or disabling features that aren't ready.
# VITE_FF_TRANSLATE=true
# VITE_FF_VOICE_ASSISTANT=true
# VITE_FF_VISION=true
# VITE_FF_CALENDAR_SYNC=true
# VITE_FF_NEARBY_PLACES=true
# VITE_FF_WEATHER=true
# VITE_FF_ROUTE_MAP=true
# VITE_FF_FAMILY_SYNC=true
# VITE_FF_FALL_DETECTION=true
# VITE_FF_BETA_FEEDBACK=true
