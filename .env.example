# Camino Pilgrim App - Environment Variables

# 1. Google Maps (Frontend and Places API)
# Get this from Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_MAPS_API_KEY=

# 2. OpenWeather (Frontend Weather API)
# Get this from OpenWeatherMap.org > API Keys 
VITE_OPENWEATHER_API_KEY=

# 3. Notion Integration (Backend Database API)
# Get this from www.notion.so/my-integrations (Make sure to share your database with this integration!)
NOTION_API_KEY=

# 4. Notion Database ID
# Get this from the URL of your full-page Notion database
# Example: https://www.notion.so/myworkspace/{THIS_IS_THE_DB_ID}?v=...
NOTION_LEADERBOARD_DB_ID=

# 5. Notion Bug Reports DB
NOTION_BUG_REPORTS_DB_ID=

# 6. Notion Feature Suggestions DB
NOTION_FEATURE_SUGGESTIONS_DB_ID=

# 7. Notion Fixer Agent Secret
NOTION_FIXER_AGENT_SECRET=
