# App URL (Required for OAuth callbacks)
# Use the App URL provided in the AI Studio runtime context
APP_URL="https://your-app-url.run.app"

# Session Secret for cookie encryption
SESSION_SECRET="a-long-random-string-here"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Maps API Key for GPS tracking and map visualization
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Google Calendar OAuth Credentials
GOOGLE_CALENDAR_CLIENT_ID="YOUR_CLIENT_ID"
GOOGLE_CALENDAR_CLIENT_SECRET="YOUR_CLIENT_SECRET"
